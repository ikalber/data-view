# Generate a strong secret with: openssl rand -base64 32
AUTH_SECRET=

# Where to keep the local SQLite store (users + saved connections, encrypted secrets)
DATA_VIEW_DB_PATH=./data/local.db

# Master key used to encrypt connection passwords at rest (AES-256-GCM, base64).
# Generate with: openssl rand -base64 32
DATA_VIEW_MASTER_KEY=

# Enable user self-signup. Set to "false" in production with admin-managed users.
ALLOW_SIGNUP=true
